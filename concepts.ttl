<http://connectivity-hub.com/terms/09b9e15e-4ed2-4cbf-975a-96086dfb65a5> a skos:Concept ;
    dcterms:modified "2025-03-14T12:00:44.313000+00:00"^^xsd:dateTime ;
    skos:broader <http://connectivity-hub.com/terms/420e8401-d58e-4f5f-80ab-6c759f121b1b> ;
    skos:editorialNote "source:UNDRR HIPS" ;
    skos:inScheme <http://connectivity-hub.com/terms/> ;
