<http://connectivity-hub.com/terms/631ab8f9-b6c3-444a-9d77-c30374d8f9cd> a skos:Concept ;
    dcterms:created "2025-06-26T14:50:49.999000+00:00"^^xsd:dateTime ;
    dcterms:modified "2025-06-26T15:00:39.512000+00:00"^^xsd:dateTime ;
    skos:broader <http://connectivity-hub.com/terms/74de1032-76aa-4ba1-b3a1-c900dc308f52> ;
    skos:definition "A situation whereby access to infrastructure services is interrupted temporarily or lost, following damage or destruction of individual assets or networks or the breakdown in the system as a whole (DRI Lexicon, 2022)."@en ;
    skos:historyNote "DRI Lexicon Project Expert Panel, October 2022."@en ;
    skos:inScheme <http://connectivity-hub.com/terms/> ;
    skos:prefLabel "Disruption and loss of services"@en ;
    skos:related <http://connectivity-hub.com/terms/ede89fb2-646d-4bdd-b791-942cad85f6f8>,
        <http://connectivity-hub.com/terms/fdcab020-8c99-4549-a816-d1eca5b4e2d1> ;
