    skos:inScheme <http://connectivity-hub.com/terms/> ;
    skos:prefLabel "Chronology"@en ;
    skos:topConceptOf <http://connectivity-hub.com/terms/> ;
    ns1:revisionNo 1 .

<http://connectivity-hub.com/terms/c68e567d-3edb-4e74-aa07-28c60ce463c3> a skos:Concept ;
