<http://connectivity-hub.com/terms/d1831632-193b-4c90-afcf-a469309e7151> a skos:Concept ;
    dcterms:modified "2025-03-14T12:00:44.313000+00:00"^^xsd:dateTime ;
    skos:definition "The propensity or predisposition to be adversely affected. Vulnerability encompasses a variety of concepts and elements, including sensitivity or susceptibility to harm and lack of capacity to cope and adapt (IPCC AR6, 2023).The susceptibility of an individual, a community, assets, or systems to the impacts of hazards can be determined by a combination of physical, social, economic, and environmental factors or processes (adapted from UNDRR, 2016 in Gill et al., 2022)."@en ;
    skos:editorialNote "source:IPCC Glossary AR6" ;
    skos:inScheme <http://connectivity-hub.com/terms/> ;
    skos:prefLabel "Vulnerability"@en ;
    skos:related <http://connectivity-hub.com/terms/18785e0a-e448-4cd3-99e7-d316f055513d>,
        <http://connectivity-hub.com/terms/28b7c1f7-ae68-4e4a-81f1-6e66bf04fd12>,
        <http://connectivity-hub.com/terms/8aef133f-b5f8-4d0f-b4d0-b66d864e9e95>,
        <http://connectivity-hub.com/terms/99596d76-6804-426b-b6fd-cbda6c842031>,
        <http://connectivity-hub.com/terms/aef81e7e-0911-4d2a-bca1-a457d62730eb>,
        <http://connectivity-hub.com/terms/ce4e88e1-769e-4c28-a843-21c3a6ecbd50>,
        <http://connectivity-hub.com/terms/d03ae38f-3bf5-4d44-963e-375065b10bf7> ;
    skos:topConceptOf <http://connectivity-hub.com/terms/> ;
