        <http://connectivity-hub.com/terms/ab7e2d30-0858-47a2-b4c6-ec48cae543cb> ;
    skos:prefLabel "Impacts"@en ;
    skos:related <http://connectivity-hub.com/terms/18785e0a-e448-4cd3-99e7-d316f055513d>,
        <http://connectivity-hub.com/terms/8623623b-9f92-40b6-b001-a76ad336d38d>,
        <http://connectivity-hub.com/terms/9a03b4e4-0c98-4e6d-b360-da0c58ee1f3d> ;
    skos:topConceptOf <http://connectivity-hub.com/terms/> ;
    ns1:revisionNo 2,
