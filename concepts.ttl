    skos:broader <http://connectivity-hub.com/terms/18785e0a-e448-4cd3-99e7-d316f055513d> ;
    skos:definition "Hydrometeorological hazards are of atmospheric, hydrological, or oceanographic origin (UNDRR, 2016 in Gill et al., 2022)."@en ;
    skos:editorialNote "source:UNDRR HIPS" ;
    skos:inScheme <http://connectivity-hub.com/terms/> ;
    skos:narrower <http://connectivity-hub.com/terms/1dfc3c6f-482b-49c4-bdd0-c5f1cc7b8916>,
        <http://connectivity-hub.com/terms/2d5b04db-bbe3-4c54-be14-c99d351bf795>,
