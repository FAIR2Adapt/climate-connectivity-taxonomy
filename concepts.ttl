<http://connectivity-hub.com/terms/d9621e9b-33e1-49b0-976c-5c91d81f4d54> a skos:Concept ;
    dcterms:created "2024-10-04T13:16:33.417000+00:00"^^xsd:dateTime ;
    dcterms:modified "2024-10-04T13:16:37.071000+00:00"^^xsd:dateTime,
        "2025-05-30T15:14:14.423000+00:00"^^xsd:dateTime ;
    skos:altLabel "waters"@en ;
    skos:inScheme <http://connectivity-hub.com/terms/> ;
    skos:prefLabel "Water"@en ;
    skos:related <http://connectivity-hub.com/terms/3206b76e-81d7-48a8-a5f9-6defa1612ddf>,
        <http://connectivity-hub.com/terms/d2bc4537-5067-4c4f-9b51-d0127923e41e>,
        <http://connectivity-hub.com/terms/fcfdb381-09d8-4b99-aa80-0a96a678f56d> ;
