        <http://connectivity-hub.com/terms/7361f763-e600-4532-a343-cf7c98ac4dae>,
        <http://connectivity-hub.com/terms/87723bec-f29d-4ff3-87ed-d14dc4fa1981>,
        <http://connectivity-hub.com/terms/a7a8a85e-dcc9-4945-8181-6ac33ca68ed9>,
        <http://connectivity-hub.com/terms/d8f2c82a-d85e-44dd-a9f6-ed5a1498b827>,
