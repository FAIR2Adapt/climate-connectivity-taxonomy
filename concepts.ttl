    ns1:revisionNo 5 .

<http://connectivity-hub.com/terms/4f118fc7-783e-4c03-8734-49c3ddab0c25> a skos:Concept ;
    dcterms:modified "2025-03-14T12:00:44.313000+00:00"^^xsd:dateTime ;
    skos:broader <http://connectivity-hub.com/terms/b41e4e12-1744-4e15-a1be-9edae8172c15> ;
    skos:editorialNote "source:UNDRR HIPS" ;
    skos:inScheme <http://connectivity-hub.com/terms/> ;
