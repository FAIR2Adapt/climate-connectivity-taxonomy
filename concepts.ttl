<http://connectivity-hub.com/terms/18785e0a-e448-4cd3-99e7-d316f055513d> a skos:Concept ;
    dcterms:modified "2025-03-14T12:00:44.313000+00:00"^^xsd:dateTime ;
    skos:definition "The potential occurrence of a natural or human-induced physical event or trend that may cause loss of life, injury, or other health impacts, as well as damage and loss to property, infrastructure, livelihoods, service provision, ecosystems and environmental resources (IPCC AR6, 2023)."@en ;
    skos:editorialNote "source:IPCC Glossary AR6" ;
    skos:inScheme <http://connectivity-hub.com/terms/> ;
    skos:narrower <http://connectivity-hub.com/terms/3154ddc4-e661-4bb8-97af-7084491793a0>,
        <http://connectivity-hub.com/terms/416bd31b-c9ab-4e0b-98d6-cf5900be93fe>,
        <http://connectivity-hub.com/terms/420e8401-d58e-4f5f-80ab-6c759f121b1b>,
        <http://connectivity-hub.com/terms/d5887606-82a8-4ab6-9e3a-5569aee8df89> ;
    skos:prefLabel "Hazard"@en ;
    skos:related <http://connectivity-hub.com/terms/2605af32-4fdf-4847-ae26-4dcac5d01622>,
        <http://connectivity-hub.com/terms/28b7c1f7-ae68-4e4a-81f1-6e66bf04fd12>,
        <http://connectivity-hub.com/terms/8aef133f-b5f8-4d0f-b4d0-b66d864e9e95>,
        <http://connectivity-hub.com/terms/99596d76-6804-426b-b6fd-cbda6c842031>,
        <http://connectivity-hub.com/terms/aef81e7e-0911-4d2a-bca1-a457d62730eb>,
        <http://connectivity-hub.com/terms/affa52fc-b12e-443d-8710-33250d80e9eb>,
        <http://connectivity-hub.com/terms/d1831632-193b-4c90-afcf-a469309e7151> ;
