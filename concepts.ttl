        <http://connectivity-hub.com/terms/ac1dd519-7571-4b65-95d7-77ef931fdcd0>,
        <http://connectivity-hub.com/terms/b033bfeb-21e8-40a6-823c-e8f83d7a8504> ;
    skos:prefLabel "Scenario"@en ;
    skos:related <http://connectivity-hub.com/terms/2bc764bb-860a-4d14-814d-72b8bdd68012> ;
    skos:topConceptOf <http://connectivity-hub.com/terms/> ;
    ns1:revisionNo 3 .

