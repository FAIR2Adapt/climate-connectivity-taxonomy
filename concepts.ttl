    skos:definition "Biological hazards are of organic origin or conveyed by biological vectors, including pathogenic microorganisms, toxins and bioactive substances (UNDRR, 2016 in Gill et al., 2022)."@en ;
    skos:editorialNote "source:UNDRR HIPS" ;
    skos:inScheme <http://connectivity-hub.com/terms/> ;
    skos:narrower <http://connectivity-hub.com/terms/09a440aa-d4ea-45b6-9c3a-5e2dcd250c14>,
