<http://connectivity-hub.com/terms/17bb4e8f-1a97-4343-95a9-d506b8a7c832> a skos:Concept ;
    dcterms:modified "2025-03-14T12:00:44.313000+00:00"^^xsd:dateTime ;
    skos:definition "The reduction of the capacity of the environment to meet social and ecological objectives and needs. Degradation of the environment can alter the frequency and intensity of natural hazards and increase the vulnerability of communities (PreventionWeb, n.d., a. in Gill et al., 2022)."@en ;
    skos:editorialNote "source:UNDRR HIPS" ;
    skos:inScheme <http://connectivity-hub.com/terms/> ;
    skos:narrower <http://connectivity-hub.com/terms/133d2809-0006-43f3-bba4-46f7e992dd2b>,
        <http://connectivity-hub.com/terms/3d5e1330-f23d-430f-af05-3ec87a1513fb>,
        <http://connectivity-hub.com/terms/58bbe0d7-cf42-4a4d-86b4-d056b663e39c>,
        <http://connectivity-hub.com/terms/5cfd3ea3-6e8d-4629-a5c3-e748bc2c5dbd>,
