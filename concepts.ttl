<http://connectivity-hub.com/terms/c549b3aa-3c1d-4f56-a631-a78c0ea8e0bf> a skos:Concept ;
    dcterms:modified "2025-03-14T12:00:44.313000+00:00"^^xsd:dateTime ;
    skos:definition "The structures, processes and actions through which private and public actors interact to address societal goals. This includes formal and informal institutions and the associated norms, rules, laws and procedures for deciding, managing, implementing and monitoring policies and measures at any geographic or political scale, from global to local."@en ;
    skos:editorialNote "source:IPCC Glossary AR6" ;
    skos:inScheme <http://connectivity-hub.com/terms/> ;
    skos:narrower <http://connectivity-hub.com/terms/0921140a-51a7-4895-9277-3a479b5d2279>,
