        <http://connectivity-hub.com/terms/9e4d33d3-9df1-45c0-a177-8132612a9d1c>,
        <http://connectivity-hub.com/terms/b053cd06-7594-45fd-98b0-8bff07ccc852>,
        <http://connectivity-hub.com/terms/cc713306-66e3-46d0-985b-f240f45980ff>,
        <http://connectivity-hub.com/terms/fdc93d5e-c5e8-46e3-a132-7a6f22d70128> ;
    skos:prefLabel "Biological hazards"@en ;
    skos:scopeNote "Examples: bacteria, viruses or parasites, as well as venomous wildlife and insects, poisonous plants and mosquitoes carrying disease-causing agents (Gill et al., 2022)."@en ;
