        <http://connectivity-hub.com/terms/f7561269-8cc6-4605-94ca-e16e35a7f688> ;
    skos:prefLabel "Transformation"@en ;
    skos:topConceptOf <http://connectivity-hub.com/terms/> ;
    ns1:revisionNo 1 .

<http://connectivity-hub.com/terms/5b58c0e2-49fe-4a7e-9754-aa60a348cbd5> a skos:Concept ;
    dcterms:created "2024-11-08T15:05:39.860000+00:00"^^xsd:dateTime ;
