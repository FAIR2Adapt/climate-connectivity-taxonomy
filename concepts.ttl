    ns1:revisionNo 7 .

<http://connectivity-hub.com/terms/416bd31b-c9ab-4e0b-98d6-cf5900be93fe> a skos:Concept ;
    dcterms:modified "2025-03-14T12:00:44.313000+00:00"^^xsd:dateTime ;
